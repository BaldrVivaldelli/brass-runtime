    "viewsWelcome": [
      {
        "view": "brassAgent.project",
        "contents": "See what Brass Agent knows about this workspace: model, language, validation command, CLI, and project profile.\n\n[Refresh](command:brassAgent.refreshProjectDashboard), [Configure Model](command:brassAgent.configureLlm), [Configure Workspace](command:brassAgent.configureWorkspace), or [Open Chat](command:brassAgent.openChat).\n\nUse [Open Project Dashboard in Editor](command:brassAgent.openProjectDashboardInEditor) for a larger dashboard."
      },
      {
        "view": "brassAgent.chat",
        "contents": "Ask Brass Agent about this workspace, selected code, failing tests, type errors, or refactors. Chat sessions remember the last run and support slash commands like `/inspect`, `/fix-tests`, `/explain-last`, and `/fix-problems`, `/fix-current-file`, and `/clear`.\n\n[Start a chat](command:brassAgent.openChat), [configure CLI auto-discovery](command:brassAgent.configureCli), or select code and use **Ask About Selection** from the editor context menu.\n\n[Configure Model](command:brassAgent.configureLlm) stores provider keys safely in VS Code Secret Storage.\n\n[Configure Workspace](command:brassAgent.configureWorkspace) creates or updates `.brass-agent.json` with language and validation-command settings.\n\nFor longer sessions, use [Open Chat in Editor](command:brassAgent.openChatInEditor)."
      },
      {
        "view": "brassAgent.runs",
        "contents": "No Brass Agent runs yet.\n\n[New Run](command:brassAgent.quickRun) starts a guided flow for inspect, propose, apply, batch, doctor, and init.\n\n[Initialize Workspace](command:brassAgent.init) creates `.brass-agent.json`, batch defaults, and safe examples.\n\n[Configure Workspace](command:brassAgent.configureWorkspace) opens a guided setup for language and validation commands.\n\n[Doctor](command:brassAgent.doctor) checks CLI, workspace, model, and VS Code setup.\n\n[Configure CLI](command:brassAgent.configureCli) switches between bundled, global, and selected CLI entrypoints.\n\n[Configure Model](command:brassAgent.configureLlm) sets up Gemini, OpenAI-compatible, or fake/offline mode."
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.9.3",
    "@vscode/vsce": "^3.6.2"
  }
}

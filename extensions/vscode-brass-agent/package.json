        "title": "Generate Test For Selection",
        "category": "Brass Agent",
        "icon": "$(beaker)"
      },
      {
        "command": "brassAgent.refactorSelection",
        "title": "Refactor Selection",
        "category": "Brass Agent",
        "icon": "$(symbol-method)"
      },
      {
        "command": "brassAgent.explainProblem",
        "title": "Explain Problem",
        "category": "Brass Agent",
        "icon": "$(book)"
      },
      {
        "command": "brassAgent.fixProblem",
        "title": "Fix Problem",
        "category": "Brass Agent",
        "icon": "$(lightbulb)"
      }
    ],
    "configuration": {
      "title": "Brass Agent",
      "properties": {
        "brassAgent.command": {
          "type": "string",
          "default": "auto",
          "description": "Command, absolute path, or auto. Use auto to let the extension prefer its bundled CLI, workspace node_modules/.bin, a brass-runtime checkout, then PATH."
        },
        "brassAgent.extraArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the agent goal."
        },
        "brassAgent.environment": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional environment variables for the brass-agent process. Secrets should preferably come from your shell or VS Code secret storage in a future version."
        },
        "brassAgent.historyLimit": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of Brass Agent runs to keep in the workspace sidebar history."
        },
        "brassAgent.storePatchesInHistory": {
          "type": "boolean",
          "default": true,
          "description": "Store proposed/applied unified diffs in VS Code workspace history so they can be reopened later. Disable if you do not want patch contents persisted in VS Code workspace storage."
        },
        "brassAgent.chatHistoryLimit": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of Brass Agent chat messages to persist in VS Code workspace storage."
        },
        "brassAgent.problemContextLimit": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of VS Code diagnostics included in Brass Agent problem-aware chat prompts."
        },
        "brassAgent.inlineAssistSurroundingLines": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "maximum": 200,
          "description": "Number of surrounding lines included when Brass Agent Inline Assist is used without an explicit selection."
        },
        "brassAgent.preferBundledCli": {
          "type": "boolean",
          "default": true,
          "description": "When brassAgent.command is auto, prefer the CLI bundled inside the VS Code extension before workspace/global discovery."
        },
        "brassAgent.nodeCommand": {
          "type": "string",
          "default": "node",
          "description": "Node.js executable used by the VS Code extension when launching a bundled JavaScript brass-agent CLI. Leave as node unless your Node binary has a custom path."
        },
        "brassAgent.llm.provider": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "google",
            "openai-compatible",
            "fake"
          ],
          "description": "LLM provider used by VS Code-launched brass-agent runs. API keys are stored in VS Code Secret Storage via Brass Agent: Configure Model."
        },
        "brassAgent.llm.google.model": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Gemini model used when brassAgent.llm.provider is google."
        },
        "brassAgent.llm.openaiCompatible.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "OpenAI-compatible /chat/completions endpoint used when brassAgent.llm.provider is openai-compatible."
        },
        "brassAgent.llm.openaiCompatible.model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "Model name used when brassAgent.llm.provider is openai-compatible."
        },
        "brassAgent.language.response": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "match-user",
            "es",
            "en",
            "pt",
            "fr",
            "de",
            "it"
          ],
          "description": "Preferred response language for VS Code-launched brass-agent runs. auto matches the user prompt when possible; es forces Spanish."
        },
        "brassAgent.chat.defaultLocation": {
          "type": "string",
          "default": "sidebar",
          "enum": [
            "sidebar",
            "editor"
          ],
          "description": "Where Brass Agent opens chat by default. Use editor for a larger focus-mode tab; sidebar keeps the chat in the Brass Agent activity view."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brassAgent",
          "title": "Brass Agent",
          "icon": "resources/brass-agent.svg"
        }
      ]
    },
    "views": {
      "brassAgent": [
        {
          "type": "webview",
          "id": "brassAgent.project",
          "name": "Project",
          "visibility": "collapsed"
        },
        {
          "type": "webview",
          "id": "brassAgent.chat",
          "name": "Chat"
        },
        {
          "id": "brassAgent.runs",
          "name": "Run History",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "brassAgent.quickRun",
          "when": "view == brassAgent.runs",
          "group": "navigation@0"
        },
        {
          "command": "brassAgent.cancel",
          "when": "view == brassAgent.runs && brassAgent.running",
          "group": "navigation@1"
        },
        {
          "command": "brassAgent.refreshHistory",
          "when": "view == brassAgent.runs",
          "group": "navigation@2"
        },
        {
          "command": "brassAgent.showOutput",
          "when": "view == brassAgent.runs",
          "group": "1_common@0"
        },
        {
          "command": "brassAgent.init",
          "when": "view == brassAgent.runs",
          "group": "1_common@1"
        },
        {
          "command": "brassAgent.doctor",
          "when": "view == brassAgent.runs",
          "group": "1_common@2"
        },
        {
          "command": "brassAgent.runConfiguredBatch",
          "when": "view == brassAgent.runs",
          "group": "2_batch@0"
        },
        {
          "command": "brassAgent.runBatchFile",
          "when": "view == brassAgent.runs",
          "group": "2_batch@1"
        },
        {

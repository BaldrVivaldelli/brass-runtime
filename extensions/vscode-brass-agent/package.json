          "when": "view == brassAgent.chat",
          "group": "navigation@0"
        },
        {
          "command": "brassAgent.configureCli",
          "when": "view == brassAgent.runs",
          "group": "1_common@3"
        },
        {
          "command": "brassAgent.configureCli",
          "when": "view == brassAgent.chat",
          "group": "1_common@0"
        },
        {
          "command": "brassAgent.configureLlm",
          "when": "view == brassAgent.chat",
          "group": "1_common@1"
        },
        {
          "command": "brassAgent.configureLlm",
          "when": "view == brassAgent.runs",
          "group": "1_common@4"
        },
        {
          "command": "brassAgent.configureWorkspace",
          "when": "view == brassAgent.chat",
          "group": "1_common@2"
        },
        {
          "command": "brassAgent.configureWorkspace",
          "when": "view == brassAgent.runs",
          "group": "1_common@5"
        },
        {
          "command": "brassAgent.refreshProjectDashboard",
          "when": "view == brassAgent.project",
          "group": "navigation@0"
        },
        {
          "command": "brassAgent.openChat",
          "when": "view == brassAgent.project",
          "group": "navigation@2"
        },
        {
          "command": "brassAgent.configureWorkspace",
          "when": "view == brassAgent.project",
          "group": "1_common@0"
        },
        {
          "command": "brassAgent.configureLlm",
          "when": "view == brassAgent.project",
          "group": "1_common@1"
        },
        {
          "command": "brassAgent.doctor",
          "when": "view == brassAgent.project",
          "group": "1_common@2"
        },
        {
          "command": "brassAgent.showOutput",
          "when": "view == brassAgent.project",
          "group": "1_common@3"
        },
        {
          "command": "brassAgent.openChatInEditor",
          "when": "view == brassAgent.chat",
          "group": "navigation@1"
        },
        {
          "command": "brassAgent.openProjectDashboardInEditor",
          "when": "view == brassAgent.project",
          "group": "navigation@1"
        },
        {
          "command": "brassAgent.focusChatLayout",
          "when": "view == brassAgent.chat",
          "group": "1_common@0"
        }
      ],
      "view/item/context": [
        {
          "command": "brassAgent.openHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentRun",
          "group": "inline"
        },
        {
          "command": "brassAgent.openHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentRunWithPatch",
          "group": "inline"
        },
        {
          "command": "brassAgent.showHistoryPatch",
          "when": "view == brassAgent.runs && viewItem == brassAgentRunWithPatch",
          "group": "inline"
        },
        {
          "command": "brassAgent.rerunHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentRun",
          "group": "navigation"
        },
        {
          "command": "brassAgent.rerunHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentRunWithPatch",
          "group": "navigation"
        },
        {
          "command": "brassAgent.rerunHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentBatch",
          "group": "navigation"
        },
        {
          "command": "brassAgent.openHistoryRun",
          "when": "view == brassAgent.runs && viewItem == brassAgentBatch",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "brassAgent.openHistoryRun",
          "when": "false"
        },
        {
          "command": "brassAgent.rerunHistoryRun",
          "when": "false"
        },
        {
          "command": "brassAgent.showHistoryPatch",
          "when": "false"
        },
        {
          "command": "brassAgent.explainProblem",
          "when": "false"
        },
        {
          "command": "brassAgent.fixProblem",
          "when": "false"
        },
        {
          "command": "brassAgent.refreshProjectDashboard",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "brassAgent.inlineAssist",
          "when": "editorTextFocus",
          "group": "brassAgent@-1"
        },
        {
          "command": "brassAgent.askSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "brassAgent@0"
        },
        {
          "command": "brassAgent.explainSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "brassAgent@1"
        },
        {
          "command": "brassAgent.fixSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "brassAgent@2"
        },
        {
          "command": "brassAgent.refactorSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "brassAgent@3"
        },
        {
          "command": "brassAgent.generateTestForSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "brassAgent@4"
        },
        {
          "command": "brassAgent.fixCurrentFileProblems",
          "when": "editorTextFocus",
          "group": "brassAgent@5"
        },
        {
          "command": "brassAgent.explainProblems",
          "when": "editorTextFocus",
          "group": "brassAgent@6"
        }
      ]

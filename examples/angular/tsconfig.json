{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "noEmit": true,
    "lib": ["DOM", "ES2022"]
  },
  "include": ["src/**/*.ts", "../shared/src/**/*.ts"]
}

